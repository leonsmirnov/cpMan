<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
    <key>CFBundleName</key>
    <string>cpMan</string>
    <key>CFBundleDisplayName</key>
    <string>cpMan</string>
    <key>CFBundleIdentifier</key>
    <string>com.cpman.app</string>
    <key>CFBundleVersion</key>
    <string>$(CURRENT_PROJECT_VERSION)</string>
    <key>CFBundleShortVersionString</key>
    <string>$(MARKETING_VERSION)</string>
    <key>CFBundlePackageType</key>
    <string>APPL</string>
    <key>CFBundleExecutable</key>
    <string>$(EXECUTABLE_NAME)</string>
    <key>LSMinimumSystemVersion</key>
    <string>14.0</string>
    <!-- Hides the app from the Dock and application switcher (Cmd+Tab) -->
    <key>LSUIElement</key>
    <true/>
    <key>NSHighResolutionCapable</key>
    <true/>
    <key>NSPrincipalClass</key>
    <string>NSApplication</string>
    <key>NSHumanReadableCopyright</key>
    <string>Copyright © 2026. All rights reserved.</string>
    <!-- App category -->
    <key>LSApplicationCategoryType</key>
    <string>public.app-category.productivity</string>
    <!-- cpMan uses no encryption beyond the standard OS/HTTPS exemptions, so it is
         exempt from export-compliance documentation. Declaring this here makes
         App Store Connect skip the encryption upload question for every build. -->
    <key>ITSAppUsesNonExemptEncryption</key>
    <false/>
    <!-- Describes why Accessibility permission is needed (shown in System Settings) -->
    <key>NSAccessibilityUsageDescription</key>
    <string>cpMan needs Accessibility access to simulate paste (⌘V) into the active app after you select a clipboard item.</string>
</dict>
</plist>
