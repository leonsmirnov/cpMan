<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
    <!--
        RELEASE entitlements
        ═══════════════════════════════════════════════════════════════════════
        Used for the Release configuration (Archive / release builds). For
        day-to-day development use cpMan-dev.entitlements instead.

        The only key declared is App Sandbox. Clipboard content is captured
        via NSPasteboard (allowed inside the sandbox by default) and stored
        as JSON in the per-app container under Application Support/cpMan.
        No network entitlement, no TCC permission, no hardened-runtime
        exemption is required.
        ═══════════════════════════════════════════════════════════════════════
    -->

    <!-- Required for release distribution -->
    <key>com.apple.security.app-sandbox</key>
    <true/>

    <!--
        Hardened Runtime — required for notarization and distribution.
        Enforced via ENABLE_HARDENED_RUNTIME = YES in project.yml.
    -->

    <!--
        Uncomment if you add iCloud sync or auto-update checks in the future:
        <key>com.apple.security.network.client</key>
        <true/>
    -->
</dict>
</plist>
