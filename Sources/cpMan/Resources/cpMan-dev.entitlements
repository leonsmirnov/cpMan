<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
    <!--
        DEBUG / DEVELOPMENT entitlements
        ═══════════════════════════════════════════════════════════════════════
        Intentionally empty. App Sandbox is OFF in dev so each ad-hoc rebuild
        does not produce a fresh sandbox container (which would reset the
        on-disk JSON history every build). The Release config
        (cpMan-release.entitlements) enables App Sandbox for distribution.

        Hardened Runtime is enforced via ENABLE_HARDENED_RUNTIME = YES in
        project.yml and applies to both configs.
        ═══════════════════════════════════════════════════════════════════════
    -->
</dict>
</plist>
